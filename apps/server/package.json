    "build": "prisma generate && tsc -p tsconfig.build.json",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@prisma/client": "^6.19.0",
    "@schrodump/core": "workspace:*",
    "age-encryption": "^0.3.0",
    "better-auth": "^1.6.24",
    "fastify": "^5.10.0",
    "pino": "^10.3.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.19.0",
    "testcontainers": "^12.0.0"
  }
}
