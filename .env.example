# Schrodump — example environment.
# Copy to .env and fill in the values. NEVER commit your real .env.

# ---------------------------------------------------------------------------
# Secrets (required) — no defaults on purpose. Leave blank here; set in .env.
# ---------------------------------------------------------------------------

# Postgres password for the Schrodump metadata database.
# Used by both the app (DATABASE_URL) and the db service.
DB_PASSWORD=

# Key-encryption key (KEK). Generate with:  openssl rand -base64 32
#
# WARNING: the KEK encrypts the keys that protect every backup. If you LOSE this
# key you LOSE access to ALL encrypted backups — there is no recovery path.
# Store it OUTSIDE this host (a secrets manager / offline vault), not next to the
# data it protects.
SCHRODUMP_KEK=

# Initial admin. Leave BOTH lines commented out to create the first admin through the one-time
# setup link printed in the logs. Do not set them to an empty value: the server validates them as
# non-empty strings, so a blank value is an invalid value and it refuses to boot.
#SCHRODUMP_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Non-secret settings — defaults shown; override only if needed.
# ---------------------------------------------------------------------------

# Public URL where Schrodump is reachable.
SCHRODUMP_URL=http://localhost:8080

# Initial admin email. See the note next to SCHRODUMP_ADMIN_PASSWORD above.
#SCHRODUMP_ADMIN_EMAIL=

# Host port to publish the web UI on.
PORT=8080

# Max bytes the local scratch volume may hold (default 100 GiB).
SCRATCH_MAX_BYTES=107374182400

# Max number of backups staged locally at the same time.
MAX_STAGED=2

# Docker network that ephemeral executors join to reach target databases.
EXECUTOR_NETWORK=schrodump_targets
